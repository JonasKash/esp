# ─────────────────────────────────────────────
# Variáveis de Ambiente — Campanha Luan
# Copie este arquivo para .env e preencha os valores
# ─────────────────────────────────────────────

# Token de acesso do Mercado Pago
# Produção: começa com APP_USR-
# Sandbox:  começa com TEST-
MERCADOPAGO_ACCESS_TOKEN=SEU_TOKEN_AQUI

# URL pública do site (sem barra no final)
# Necessário para configurar o Webhook de notificação de pagamento
# Deve usar HTTPS para que o Mercado Pago aceite
BASE_URL=https://seusite.com
